meta {
  name: Get Items
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/items
  body: none
  auth: apikey
}

auth:apikey {
  key: x-api
  value: {{x-api-key}}
  placement: header
}

params:query {
  ~type: Attack
  ~tier: 3
  ~page: 1
  ~limit: 20
}

tests {
  test("returns 200", function () {
    expect(res.status).to.equal(200);
  });

  test("returns array", function () {
    expect(res.body).to.be.an("array");
  });
}

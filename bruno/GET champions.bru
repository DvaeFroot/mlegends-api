meta {
  name: Get Champions
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/champions
  body: none
  auth: apikey
}

auth:apikey {
  key: x-api
  value: {{x-api-key}}
  placement: header
}

params:query {
  ~role: Tank
  ~specialty: Crowd Control
  ~page: 1
  ~limit: 20
}

tests {
  test("returns 200", function () {
    expect(res.status).to.equal(200);
  });

  test("returns array", function () {
    expect(res.body).to.be.an("array");
  });
}
